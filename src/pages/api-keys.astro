---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import providers from '../data/api-providers.json';

const freeProviders = providers.filter(p => p.free_tier);
const paidProviders = providers.filter(p => !p.free_tier);

const useCaseSet = new Set<string>();
providers.forEach(p => p.use_cases.forEach(u => useCaseSet.add(u)));
const useCases = ['Alle', ...Array.from(useCaseSet).sort()];
---

<Layout
  title="API Keys für KI — Wo & wie bekomme ich sie?"
  description="Übersicht aller KI API-Anbieter mit kostenlosen und bezahlten Keys. Ohne Credit Card starten."
>
  <Header />

  <main class="max-w-7xl mx-auto px-4 py-10">
    <!-- Hero -->
    <section class="text-center mb-12">
      <div class="text-5xl mb-4">🔑</div>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3 leading-tight">
        API Keys für KI-Dienste
      </h1>
      <p class="text-zinc-400 text-base max-w-2xl mx-auto mb-2">
        Wo du kostenlose und bezahlte API Keys bekommst — für LLMs, Bilder, Audio, Video und mehr.
        Sortiert nach: erst kostenlos, dann bezahlt.
      </p>
      <div class="flex items-center justify-center gap-4 mt-4 text-sm">
        <span class="flex items-center gap-1.5 text-emerald-400">
          <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
          {freeProviders.length} mit kostenlosem Tier
        </span>
        <span class="flex items-center gap-1.5 text-zinc-500">
          <span class="w-2 h-2 rounded-full bg-zinc-500"></span>
          {paidProviders.length} nur bezahlt
        </span>
      </div>
    </section>

    <!-- Filter Bar -->
    <div class="flex flex-wrap gap-3 mb-6 items-center">
      <!-- Free toggle -->
      <label class="flex items-center gap-2 cursor-pointer group">
        <input type="checkbox" id="free-only" class="w-4 h-4 rounded accent-emerald-500 cursor-pointer" />
        <span class="text-sm text-zinc-400 group-hover:text-white transition-colors select-none">Nur kostenlos</span>
      </label>
      <div class="w-px h-5 bg-zinc-700"></div>
      <!-- Use case filter -->
      <div class="flex flex-wrap gap-2" id="usecase-filter">
        {useCases.map(uc => (
          <button
            data-usecase={uc}
            class={`text-xs px-3 py-1.5 rounded-full border transition-colors ${uc === 'Alle' ? 'bg-indigo-600 border-indigo-500 text-white' : 'bg-zinc-900 border-zinc-700 text-zinc-400 hover:border-indigo-500 hover:text-white'}`}
          >
            {uc}
          </button>
        ))}
      </div>
    </div>

    <!-- Count -->
    <p class="text-zinc-500 text-sm mb-6" id="results-count">{providers.length} Anbieter</p>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="providers-grid">
      {providers.map(p => {
        const initials = p.name.slice(0, 2).toUpperCase();
        return (
          <div
            class="provider-card relative flex flex-col rounded-xl border border-zinc-800 bg-[#1a1a1a] p-5 hover:border-indigo-500/50 hover:shadow-[0_0_20px_rgba(99,102,241,0.1)] transition-all duration-200"
            data-free={p.free_tier ? 'true' : 'false'}
            data-usecases={p.use_cases.join(' ')}
            data-name={p.name.toLowerCase()}
          >
            <!-- Free badge -->
            {p.free_tier && !p.credit_card_required && (
              <span class="absolute top-3 right-3 text-xs font-semibold px-2 py-0.5 rounded-full bg-emerald-900/60 border border-emerald-700 text-emerald-300">
                ✓ Kostenlos
              </span>
            )}
            {p.free_tier && p.credit_card_required && (
              <span class="absolute top-3 right-3 text-xs font-semibold px-2 py-0.5 rounded-full bg-yellow-900/40 border border-yellow-700 text-yellow-300">
                Free Trial
              </span>
            )}
            {!p.free_tier && (
              <span class="absolute top-3 right-3 text-xs font-semibold px-2 py-0.5 rounded-full bg-zinc-800 border border-zinc-700 text-zinc-400">
                💳 Bezahlt
              </span>
            )}

            <!-- Header -->
            <div class="flex items-start gap-3 mb-3">
              <div class="flex-none w-10 h-10 rounded-lg overflow-hidden bg-zinc-800 flex items-center justify-center text-sm font-bold text-zinc-400">
                {p.logo_url ? (
                  <img
                    src={p.logo_url}
                    alt={p.name}
                    width="40"
                    height="40"
                    class="w-full h-full object-contain"
                    onerror="this.style.display='none';this.nextSibling.style.display='flex'"
                  />
                ) : null}
                <span class={p.logo_url ? 'hidden' : ''}>{initials}</span>
              </div>
              <div class="flex-1 min-w-0 pr-16">
                <h3 class="font-bold text-white text-base leading-tight">{p.name}</h3>
                <p class="text-xs text-zinc-400 mt-0.5 leading-snug">{p.tagline}</p>
              </div>
            </div>

            <!-- Description -->
            <p class="text-sm text-zinc-300 leading-relaxed mb-3 line-clamp-2">{p.description}</p>

            <!-- Free details -->
            {p.free_tier && p.free_details && (
              <div class="flex items-start gap-1.5 text-xs text-emerald-400 mb-2">
                <span class="mt-0.5 flex-none">✓</span>
                <span>{p.free_details}</span>
              </div>
            )}
            {p.credit_card_required && (
              <div class="flex items-start gap-1.5 text-xs text-yellow-500 mb-2">
                <span class="mt-0.5 flex-none">💳</span>
                <span>Credit Card erforderlich</span>
              </div>
            )}

            <!-- Models -->
            <div class="flex flex-wrap gap-1.5 mb-3">
              {p.models.slice(0, 4).map(m => (
                <span class="text-xs px-2 py-0.5 rounded-full bg-zinc-800 text-zinc-400 border border-zinc-700">{m}</span>
              ))}
              {p.models.length > 4 && (
                <span class="text-xs px-2 py-0.5 rounded-full bg-zinc-800 text-zinc-500 border border-zinc-700">+{p.models.length - 4}</span>
              )}
            </div>

            <!-- Use cases -->
            <div class="flex flex-wrap gap-1.5 mb-4">
              {p.use_cases.map(uc => (
                <span class="text-xs px-2 py-0.5 rounded-full bg-indigo-900/30 text-indigo-400 border border-indigo-800/50">{uc}</span>
              ))}
            </div>

            <!-- Footer -->
            <div class="mt-auto flex items-center justify-between pt-3 border-t border-zinc-800">
              <div class="flex">
                {Array.from({ length: 5 }).map((_, i) => (
                  <span class={`text-sm ${i < p.rating ? 'text-yellow-400' : 'text-zinc-700'}`}>★</span>
                ))}
              </div>
              <div class="flex items-center gap-3">
                {p.docs_url && (
                  <a
                    href={p.docs_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors"
                  >
                    Docs
                  </a>
                )}
                <a
                  href={p.get_key_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs font-semibold text-indigo-400 hover:text-indigo-300 transition-colors"
                >
                  Key holen →
                </a>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="hidden text-center py-20">
      <p class="text-4xl mb-4">🔍</p>
      <p class="text-zinc-400">Keine Anbieter gefunden.</p>
    </div>
  </main>

  <footer class="border-t border-zinc-800 mt-16 py-8 text-center text-zinc-600 text-sm">
    <p>AI Tools Directory · Stand April 2026 · Kein Affiliate-Tracking</p>
  </footer>
</Layout>

<script>
  const freeOnly = document.getElementById('free-only') as HTMLInputElement;
  const usecaseButtons = document.querySelectorAll('#usecase-filter button');
  const cards = document.querySelectorAll('.provider-card') as NodeListOf<HTMLElement>;
  const resultsCount = document.getElementById('results-count')!;
  const emptyState = document.getElementById('empty-state')!;

  let activeUsecase = 'Alle';
  let onlyFree = false;

  function filter() {
    let visible = 0;
    cards.forEach(card => {
      const isFree = card.dataset.free === 'true';
      const usecases = card.dataset.usecases ?? '';
      const matchFree = !onlyFree || isFree;
      const matchUsecase = activeUsecase === 'Alle' || usecases.includes(activeUsecase);
      if (matchFree && matchUsecase) {
        card.classList.remove('hidden');
        visible++;
      } else {
        card.classList.add('hidden');
      }
    });
    resultsCount.textContent = `${visible} Anbieter`;
    emptyState.classList.toggle('hidden', visible > 0);
  }

  freeOnly.addEventListener('change', () => { onlyFree = freeOnly.checked; filter(); });

  usecaseButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      activeUsecase = (btn as HTMLElement).dataset.usecase ?? 'Alle';
      usecaseButtons.forEach(b => {
        b.classList.remove('bg-indigo-600', 'border-indigo-500', 'text-white');
        b.classList.add('bg-zinc-900', 'border-zinc-700', 'text-zinc-400');
      });
      btn.classList.add('bg-indigo-600', 'border-indigo-500', 'text-white');
      btn.classList.remove('bg-zinc-900', 'border-zinc-700', 'text-zinc-400');
      filter();
    });
  });
</script>
