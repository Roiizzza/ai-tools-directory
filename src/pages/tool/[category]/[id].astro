---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import PriceBadge from '../../../components/PriceBadge.astro';

export async function getStaticPaths() {
  const modules = import.meta.glob('../../../data/categories/*.json', { eager: true });
  const paths: any[] = [];
  for (const f of Object.values(modules) as any[]) {
    for (const tool of f.tools) {
      paths.push({
        params: { category: f.category.slug, id: tool.id },
        props: { tool, category: f.category },
      });
    }
  }
  return paths;
}

const { tool, category } = Astro.props as any;
const initials = tool.name.slice(0, 2).toUpperCase();
---

<Layout
  title={`${tool.name} — ${category.name} · AI Tools Directory`}
  description={tool.tagline}
>
  <Header />

  <main class="max-w-3xl mx-auto px-4 py-10">
    <!-- Breadcrumb -->
    <nav class="text-sm text-zinc-500 mb-8 flex flex-wrap gap-1 items-center">
      <a href="/" class="hover:text-white transition-colors">Übersicht</a>
      <span class="mx-1">›</span>
      <a href="/tools" class="hover:text-white transition-colors">KI-Tools</a>
      <span class="mx-1">›</span>
      <a href={`/category/${category.slug}`} class="hover:text-white transition-colors">{category.emoji} {category.name}</a>
      <span class="mx-1">›</span>
      <span class="text-white">{tool.name}</span>
    </nav>

    <!-- Tool Header -->
    <div class="flex items-start gap-5 mb-8">
      <div class="flex-none w-16 h-16 rounded-xl overflow-hidden bg-zinc-800 flex items-center justify-center text-xl font-bold text-zinc-400">
        {tool.logo_url ? (
          <img
            src={tool.logo_url}
            alt={tool.name}
            width="64"
            height="64"
            class="w-full h-full object-contain"
            onerror="this.style.display='none';this.nextSibling.style.display='flex'"
          />
        ) : null}
        <span class={tool.logo_url ? 'hidden' : ''}>{initials}</span>
      </div>
      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap items-center gap-2 mb-1">
          <h1 class="text-2xl sm:text-3xl font-bold text-white">{tool.name}</h1>
          {tool.editor_pick && (
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-indigo-900/60 border border-indigo-700 text-indigo-300">★ Editor's Pick</span>
          )}
          {tool.is_open_source && (
            <span class="text-xs px-2 py-0.5 rounded bg-zinc-700 text-zinc-400">OSS</span>
          )}
        </div>
        <p class="text-zinc-400 text-base">{tool.tagline}</p>
      </div>
    </div>

    <!-- Description -->
    <div class="rounded-xl border border-zinc-800 bg-[#1a1a1a] p-6 mb-6">
      <p class="text-zinc-300 leading-relaxed">{tool.description}</p>
    </div>

    <!-- Strengths & Weaknesses -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
      <div class="rounded-xl border border-zinc-800 bg-[#1a1a1a] p-5">
        <h2 class="text-sm font-semibold text-emerald-400 mb-3 uppercase tracking-wide">Stärken</h2>
        <ul class="space-y-2">
          {tool.strengths.map((s: string) => (
            <li class="flex items-start gap-2 text-sm text-zinc-300">
              <span class="mt-0.5 text-emerald-400 flex-none">✓</span>
              <span>{s}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-xl border border-zinc-800 bg-[#1a1a1a] p-5">
        <h2 class="text-sm font-semibold text-red-400 mb-3 uppercase tracking-wide">Schwächen</h2>
        <ul class="space-y-2">
          {tool.weaknesses.map((w: string) => (
            <li class="flex items-start gap-2 text-sm text-zinc-300">
              <span class="mt-0.5 text-red-400 flex-none">✗</span>
              <span>{w}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Pricing -->
    <div class="rounded-xl border border-zinc-800 bg-[#1a1a1a] p-5 mb-6">
      <h2 class="text-sm font-semibold text-zinc-400 mb-3 uppercase tracking-wide">Preismodell</h2>
      <div class="flex items-center gap-3 flex-wrap">
        <PriceBadge pricing={tool.pricing} />
        {tool.pricing.price_note && (
          <span class="text-sm text-zinc-400">{tool.pricing.price_note}</span>
        )}
      </div>
      {tool.pricing.starting_price != null && (
        <p class="text-sm text-zinc-500 mt-2">
          Ab {tool.pricing.starting_price} {tool.pricing.currency ?? 'USD'}/Mo
          {tool.pricing.free_tier && ' · Kostenloses Tier verfügbar'}
        </p>
      )}
    </div>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mb-8">
      {tool.tags.map((tag: string) => (
        <span class="text-xs px-2.5 py-1 rounded-full bg-zinc-800 text-zinc-400 border border-zinc-700">{tag}</span>
      ))}
    </div>

    <!-- CTA -->
    <div class="flex items-center gap-4 flex-wrap">
      <a
        href={tool.website}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white font-semibold transition-colors"
      >
        {tool.name} öffnen →
      </a>
      <a href={`/category/${category.slug}`} class="text-sm text-zinc-400 hover:text-white transition-colors">
        ← Zurück zu {category.name}
      </a>
    </div>

    {tool.last_updated && (
      <p class="text-xs text-zinc-600 mt-8">Zuletzt aktualisiert: {tool.last_updated}</p>
    )}
  </main>

  <footer class="border-t border-zinc-800 mt-16 py-8 text-center text-zinc-600 text-sm">
    <p>AI Tools Directory · Stand April 2026 · Kein Affiliate-Tracking</p>
  </footer>
</Layout>
