---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import apiProviders from '../data/api-providers.json';
import skills from '../data/claude-skills.json';

const categoryModules = import.meta.glob('../data/categories/*.json', { eager: true });
const categoryFiles = Object.values(categoryModules) as any[];
const categories = categoryFiles.map((f: any) => f.category);
const totalTools = categoryFiles.reduce((sum: number, f: any) => sum + f.tools.length, 0);
const freeApiCount = apiProviders.filter(p => p.free_tier).length;
const editorPicks = categoryFiles
  .flatMap((f: any) => f.tools.map((t: any) => ({ ...t, categorySlug: f.category.slug, categoryName: f.category.name, categoryEmoji: f.category.emoji })))
  .filter((t: any) => t.editor_pick)
  .slice(0, 3);

const sections = [
  {
    href: '/tools',
    icon: '🛠',
    title: 'KI-Tools',
    description: 'Alle KI-Tools mit echten Stärken und Schwächen bewertet. Suche nach Anwendungsfall — von PowerPoint bis Coding.',
    stat: `${totalTools} Tools · ${categories.length} Kategorien`,
    color: 'indigo',
  },
  {
    href: '/api-keys',
    icon: '🔑',
    title: 'API Keys',
    description: 'Wo bekommst du kostenlose oder bezahlte API Keys? Alle Anbieter auf einen Blick — mit Free-Tier-Info.',
    stat: `${apiProviders.length} Anbieter · ${freeApiCount} kostenlos`,
    color: 'emerald',
  },
  {
    href: '/claude-skills',
    icon: '⚡',
    title: 'Claude Code Skills',
    description: 'Slash-Commands für Claude Code: Built-in, Marketplace und eigene Custom Skills mit Installationsanleitung.',
    stat: `${skills.length} Skills · 4 Typen`,
    color: 'purple',
  },
  {
    href: '/idea',
    icon: '💡',
    title: 'KI-Berater',
    description: 'Beschreibe deine Idee — die KI empfiehlt die passenden Tools aus dem Verzeichnis. Kostenlose Tools bevorzugbar.',
    stat: 'NVIDIA powered · Streaming',
    color: 'amber',
  },
];

const colorMap: Record<string, string> = {
  indigo: 'border-indigo-800/50 hover:border-indigo-500/60 hover:shadow-[0_0_30px_rgba(99,102,241,0.12)]',
  emerald: 'border-emerald-800/50 hover:border-emerald-500/60 hover:shadow-[0_0_30px_rgba(16,185,129,0.12)]',
  purple:  'border-purple-800/50 hover:border-purple-500/60 hover:shadow-[0_0_30px_rgba(168,85,247,0.12)]',
  amber:   'border-amber-800/50 hover:border-amber-500/60 hover:shadow-[0_0_30px_rgba(245,158,11,0.12)]',
};
const iconBgMap: Record<string, string> = {
  indigo: 'bg-indigo-950/60 text-indigo-300',
  emerald: 'bg-emerald-950/60 text-emerald-300',
  purple: 'bg-purple-950/60 text-purple-300',
  amber: 'bg-amber-950/60 text-amber-300',
};
const statColorMap: Record<string, string> = {
  indigo: 'text-indigo-400',
  emerald: 'text-emerald-400',
  purple: 'text-purple-400',
  amber: 'text-amber-400',
};
---

<Layout
  title="AI Tools Directory — KI-Tools, API Keys, Claude Skills"
  description="Dein KI-Werkzeugkasten: 40 KI-Tools ehrlich bewertet, 19 API-Anbieter, 37 Claude Code Skills und ein KI-Berater."
>
  <Header />

  <main class="max-w-5xl mx-auto px-4 py-12">

    <!-- Hero -->
    <section class="text-center mb-14">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-800 border border-zinc-700 text-xs text-zinc-400 mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
        Stand April 2026 · Kein Affiliate-Tracking
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4 leading-tight tracking-tight">
        Dein KI-Werkzeugkasten
      </h1>
      <p class="text-zinc-400 text-lg max-w-xl mx-auto">
        KI-Tools ehrlich bewertet. API Keys übersichtlich. Claude Skills dokumentiert.
      </p>
    </section>

    <!-- Stats Bar -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-12">
      {[
        { n: totalTools,              label: 'KI-Tools' },
        { n: categories.length,       label: 'Kategorien' },
        { n: apiProviders.length,     label: 'API-Anbieter' },
        { n: skills.length,           label: 'Claude Skills' },
      ].map(s => (
        <div class="rounded-xl border border-zinc-800 bg-zinc-900/50 p-4 text-center">
          <div class="text-2xl font-bold text-white">{s.n}</div>
          <div class="text-xs text-zinc-500 mt-0.5">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- 4 Section Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-14">
      {sections.map(s => (
        <a
          href={s.href}
          class={`group relative flex flex-col rounded-2xl border bg-[#1a1a1a] p-6 transition-all duration-300 ${colorMap[s.color]}`}
        >
          <div class={`w-10 h-10 rounded-xl flex items-center justify-center text-xl mb-4 ${iconBgMap[s.color]}`}>
            {s.icon}
          </div>
          <h2 class="text-lg font-bold text-white mb-2 group-hover:text-white/90">{s.title}</h2>
          <p class="text-sm text-zinc-400 leading-relaxed mb-4 flex-1">{s.description}</p>
          <div class="flex items-center justify-between mt-auto pt-3 border-t border-zinc-800">
            <span class={`text-xs font-medium ${statColorMap[s.color]}`}>{s.stat}</span>
            <span class="text-zinc-600 group-hover:text-zinc-400 transition-colors text-sm">→</span>
          </div>
        </a>
      ))}
    </div>

    <!-- Kategorien -->
    <section class="mb-14">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-lg font-bold text-white">Tool-Kategorien</h2>
        <a href="/tools" class="text-sm text-zinc-500 hover:text-white transition-colors">Alle Tools →</a>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {categories.map((cat: any) => (
          <a
            href={`/category/${cat.slug}`}
            class="flex items-center gap-2.5 rounded-xl border border-zinc-800 bg-[#1a1a1a] px-4 py-3 hover:border-indigo-500/50 hover:bg-zinc-800/50 transition-all group"
          >
            <span class="text-xl">{cat.emoji}</span>
            <span class="text-sm text-zinc-300 group-hover:text-white transition-colors font-medium truncate">{cat.name}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Editor Picks -->
    {editorPicks.length > 0 && (
      <section>
        <div class="flex items-center justify-between mb-5">
          <h2 class="text-lg font-bold text-white">★ Editor's Picks</h2>
          <a href="/tools" class="text-sm text-zinc-500 hover:text-white transition-colors">Alle durchsuchen →</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {editorPicks.map((t: any) => (
            <a
              href={`/tool/${t.categorySlug}/${t.id}`}
              class="flex flex-col rounded-xl border border-zinc-800 bg-[#1a1a1a] p-4 hover:border-indigo-500/40 transition-all group"
            >
              <div class="flex items-center gap-3 mb-3">
                <div class="w-9 h-9 rounded-lg bg-zinc-800 flex items-center justify-center text-xs font-bold text-zinc-400 overflow-hidden flex-none">
                  {t.logo_url
                    ? <img src={t.logo_url} alt={t.name} width="36" height="36" class="w-full h-full object-contain" onerror="this.style.display='none'" />
                    : t.name.slice(0,2).toUpperCase()
                  }
                </div>
                <div>
                  <div class="text-sm font-bold text-white">{t.name}</div>
                  <div class="text-xs text-zinc-500">{t.categoryEmoji} {t.categoryName}</div>
                </div>
              </div>
              <p class="text-xs text-zinc-400 line-clamp-2 leading-relaxed">{t.tagline}</p>
            </a>
          ))}
        </div>
      </section>
    )}

  </main>

  <footer class="border-t border-zinc-800 mt-16 py-8 text-center text-zinc-600 text-sm">
    <p>AI Tools Directory · Stand April 2026 · Kein Affiliate-Tracking</p>
  </footer>
</Layout>
