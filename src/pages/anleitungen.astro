---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const glossary = [
  { term: 'LLM', full: 'Large Language Model', cat: 'Modelle', def: 'Ein KI-Modell, das auf riesigen Textmengen trainiert wurde und menschliche Sprache verstehen und erzeugen kann.', ex: 'GPT-4, Claude, Gemini, Llama sind bekannte LLMs.' },
  { term: 'Token', full: 'Textbaustein', cat: 'Konzepte', def: 'Kleinste Einheit, die ein LLM verarbeitet — ca. ¾ eines Wortes. Kosten und Limits werden in Tokens gemessen.', ex: '"Hallo Welt" ≈ 3 Tokens. 1.000 Tokens ≈ 750 Wörter.' },
  { term: 'Prompt', full: 'Eingabeaufforderung', cat: 'Konzepte', def: 'Der Text, den du an ein KI-Modell sendest. Die Qualität des Prompts bestimmt die Qualität der Antwort.', ex: '"Erkläre mir Python, als wäre ich 10 Jahre alt."' },
  { term: 'Context Window', full: 'Kontextfenster', cat: 'Konzepte', def: 'Die max. Anzahl Tokens, die ein Modell gleichzeitig "sehen" kann. Alles außerhalb wird vergessen.', ex: 'Claude: 200.000 Tokens ≈ 150.000 Wörter.' },
  { term: 'API', full: 'Application Programming Interface', cat: 'Werkzeuge', def: 'Schnittstelle zwischen Programmen. KI-APIs erlauben es, KI-Funktionen in eigene Apps einzubauen.', ex: 'Du rufst die Anthropic API auf → Claude antwortet in deiner App.' },
  { term: 'API Key', full: 'API-Schlüssel', cat: 'Sicherheit', def: 'Einzigartiger Code, der dich als berechtigten API-Nutzer identifiziert. Wie ein Passwort — niemals teilen!', ex: 'sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx' },
  { term: 'Halluzination', full: 'KI-Halluzination', cat: 'Konzepte', def: 'Wenn ein KI-Modell selbstbewusst falsche oder frei erfundene Informationen präsentiert.', ex: 'KI nennt eine nicht-existierende Studie mit korrektem Autor und Jahreszahl.' },
  { term: 'Temperature', full: 'Kreativitäts-Parameter', cat: 'Modelle', def: 'Steuert Kreativität der Antworten. 0 = präzise und deterministisch. 1 = kreativ und variabel.', ex: 'Für Code: 0.2 | Für Kreativtexte: 0.8–1.0' },
  { term: 'System Prompt', full: 'Systemanweisung', cat: 'Konzepte', def: 'Unsichtbare Vorabanweisung, die Modell-Verhalten und Persona definiert. Wird vor dem Chat gesetzt.', ex: '"Du bist ein präziser Assistent. Antworte immer auf Deutsch."' },
  { term: 'RAG', full: 'Retrieval Augmented Generation', cat: 'Konzepte', def: 'Technik: Erst Dokumente aus Datenbank laden, dann als Kontext an Modell übergeben. Reduziert Halluzinationen.', ex: 'Eigene PDFs durchsuchen lassen — ohne Fine-Tuning.' },
  { term: 'Fine-Tuning', full: 'Feinabstimmung', cat: 'Modelle', def: 'Vortrainiertes Modell mit eigenen Daten weitertrainieren, damit es für spezifische Aufgaben besser funktioniert.', ex: 'Modell auf Support-Dialoge trainieren → präzisere Antworten.' },
  { term: 'Embedding', full: 'Vektordarstellung', cat: 'Konzepte', def: 'Text wird in Zahlen-Vektoren umgewandelt, die semantische Ähnlichkeit abbilden. Basis für Suche und RAG.', ex: '"König" − "Mann" + "Frau" ≈ "Königin" — als Vektoren gerechnet.' },
  { term: 'Agent', full: 'KI-Agent', cat: 'Werkzeuge', def: 'KI, die selbstständig Aufgaben ausführt: Tools nutzen, Code ausführen, Browser steuern — nicht nur antworten.', ex: 'Claude Code ist ein Agent — er liest, schreibt und verändert Dateien.' },
  { term: 'Open Source', full: 'Offener Quellcode', cat: 'Modelle', def: 'Modelle, deren Gewichte öffentlich sind. Lokal betreibbar — keine API-Kosten, volle Kontrolle.', ex: 'Llama 3.1, Mistral, Qwen 2.5, Phi-4 sind Open-Source.' },
  { term: 'Multimodal', full: 'Mehrmodale KI', cat: 'Modelle', def: 'KI, die verschiedene Datentypen verarbeitet: Text, Bilder, Audio, Video.', ex: 'GPT-4o, Gemini 1.5 Pro, Claude 3 sind multimodal.' },
  { term: 'Parameter', full: 'Modell-Parameter', cat: 'Modelle', def: 'Die "Gewichte" eines Modells — gelernte Verbindungen aus dem Training. Mehr = größere Kapazität.', ex: 'Llama 3.1: 405 Mrd. Parameter. GPT-4: ~1,7 Bio. (geschätzt).' },
  { term: 'Inference', full: 'Modell-Inferenz', cat: 'Modelle', def: 'Der Vorgang, wenn ein Modell eine Anfrage verarbeitet und antwortet. Jeder API-Call = eine Inference.', ex: 'Jede Antwort von Claude = ein Inference-Durchlauf.' },
  { term: 'Prompt Engineering', full: 'Prompt-Gestaltung', cat: 'Konzepte', def: 'Die Kunst, Prompts so zu formulieren, dass KI-Modelle optimal antworten. Eigene Disziplin.', ex: 'Chain-of-Thought: "Denke Schritt für Schritt..." verbessert Logik um ~30%.' },
  { term: 'MCP', full: 'Model Context Protocol', cat: 'Werkzeuge', def: 'Anthropic-Standard um Claude mit externen Tools zu verbinden. Universelle Steckdose für KI-Integrationen.', ex: 'MCP-Server für GitHub, Datenbanken, Browser, Dateisystem.' },
  { term: 'Benchmark', full: 'Leistungsvergleichstest', cat: 'Modelle', def: 'Standardisierte Tests zum Vergleich von KI-Modellen. Spiegeln nicht immer echte Alltagsqualität wider.', ex: 'MMLU (Wissen), HumanEval (Code), GPQA (Wissenschaft).' },
  { term: 'Latenz', full: 'Antwortzeit', cat: 'Werkzeuge', def: 'Zeit zwischen Anfrage und erster Antwort. Gemessen als "Time to First Token" (TTFT).', ex: 'Schnelle Modelle: <500ms TTFT. Reasoning-Modelle: 10–60s.' },
  { term: 'CLAUDE.md', full: 'Konfigurations-Datei', cat: 'Werkzeuge', def: 'Spezielle Datei, die Claude Code Projekt-Kontext gibt: Regeln, Codebase-Infos. Wird automatisch geladen.', ex: 'CLAUDE.md im Projekt-Root → Claude kennt deine Regeln.' },
];

const catClass: Record<string, string> = {
  Modelle: 'cat-modelle', Werkzeuge: 'cat-werkzeuge',
  Sicherheit: 'cat-sicherheit', Konzepte: 'cat-konzepte',
};
const catBadge: Record<string, string> = {
  Modelle: 'badge-purple', Werkzeuge: 'badge-blue',
  Sicherheit: 'badge-red', Konzepte: 'badge-amber',
};
const cats = ['Alle', ...Array.from(new Set(glossary.map(g => g.cat))).sort()];

const builtinSkills = [
  { cmd: '/help',    desc: 'Alle verfügbaren Befehle anzeigen' },
  { cmd: '/clear',   desc: 'Kontext leeren — frische Unterhaltung starten' },
  { cmd: '/review',  desc: 'Code-Review für aktuelle Änderungen' },
  { cmd: '/init',    desc: 'CLAUDE.md Konfigurationsdatei erstellen' },
  { cmd: '/compact', desc: 'Kontext komprimieren und Platz sparen' },
  { cmd: '/config',  desc: 'Claude Code Einstellungen öffnen' },
  { cmd: '/cost',    desc: 'API-Kosten der aktuellen Sitzung anzeigen' },
  { cmd: '/status',  desc: 'Git-Status und aktuelle Aufgaben anzeigen' },
];

const customSkillContent = `---
name: mein-skill
description: Analysiert Code und gibt Verbesserungsvorschläge
---

Analysiere den aktuellen Code und gib genau 3
priorisierte Verbesserungsvorschläge:

1. Sicherheit & Bugs — was könnte kaputt gehen?
2. Performance — wo ist es ineffizient?
3. Lesbarkeit — was ist schwer zu verstehen?

Halte jeden Vorschlag unter 3 Sätzen.`;

const envHighlighted = `<span style="color:#4b5563"># KI-APIs</span>
<span style="color:#fbbf24">ANTHROPIC_API_KEY</span><span style="color:#6b7280">=</span><span style="color:#6ee7b7">sk-ant-api03-xxxxxxxxxxxxxxxxxxxx</span>
<span style="color:#fbbf24">OPENAI_API_KEY</span><span style="color:#6b7280">=</span><span style="color:#6ee7b7">sk-proj-xxxxxxxxxxxxxxxxxxxx</span>
<span style="color:#fbbf24">GOOGLE_AI_API_KEY</span><span style="color:#6b7280">=</span><span style="color:#6ee7b7">AIzaxxxxxxxxxxxxxxxxxxxxxxx</span>

<span style="color:#4b5563"># Datenbank</span>
<span style="color:#fbbf24">DATABASE_URL</span><span style="color:#6b7280">=</span><span style="color:#6ee7b7">postgresql://user:password@localhost:5432/mydb</span>

<span style="color:#4b5563"># App-Konfiguration</span>
<span style="color:#fbbf24">APP_PORT</span><span style="color:#6b7280">=</span><span style="color:#6ee7b7">3000</span>
<span style="color:#fbbf24">NODE_ENV</span><span style="color:#6b7280">=</span><span style="color:#6ee7b7">development</span>
<span style="color:#fbbf24">DEBUG</span><span style="color:#6b7280">=</span><span style="color:#6ee7b7">false</span>`;

const gitignoreHL = `<span style="color:#f87171">.env</span>
<span style="color:#f87171">.env.local</span>
<span style="color:#f87171">.env.*.local</span>
<span style="color:#f87171">.env.production</span>`;

const envRaw = `# KI-APIs\nANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx\nOPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx\nGOOGLE_AI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxx\n\n# Datenbank\nDATABASE_URL=postgresql://user:password@localhost:5432/mydb\n\n# App-Konfiguration\nAPP_PORT=3000\nNODE_ENV=development\nDEBUG=false`;
---

<Layout
  title="KI-Anleitungen für Einsteiger — Skills, API, .env erklärt"
  description="KI-Glossar mit 22 Begriffen, Claude Skills einbinden, API Keys verbinden, .env Dateien — alles Schritt für Schritt für Einsteiger."
>
  <Header />

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=JetBrains+Mono:wght@400;500&display=swap');

    .an-page { font-family: 'DM Sans', system-ui, sans-serif; background: #09090c; }
    .f-syne  { font-family: 'Syne', sans-serif; }
    .f-mono  { font-family: 'JetBrains Mono', monospace; }

    /* ── Watermark ── */
    .s-watermark {
      position: absolute; right: 0; top: -2rem;
      font-family: 'Syne', sans-serif;
      font-size: clamp(5rem, 14vw, 10rem);
      font-weight: 800; letter-spacing: -0.05em;
      color: rgba(255,255,255,0.022); line-height: 1;
      pointer-events: none; user-select: none;
    }

    /* ── Card base ── */
    .an-card {
      background: #0d0d10;
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 12px;
      transition: border-color 200ms, box-shadow 200ms;
    }
    .an-card:hover { border-color: rgba(255,255,255,0.14); box-shadow: 0 8px 32px rgba(0,0,0,0.4); }

    /* ── Glossar card with left accent ── */
    .g-card { position: relative; padding-left: 1.25rem; }
    .g-card::before {
      content: ''; position: absolute;
      left: 0; top: 10px; bottom: 10px;
      width: 2px; border-radius: 2px;
    }
    .g-card.cat-modelle::before   { background: rgba(167,139,250,0.75); }
    .g-card.cat-werkzeuge::before { background: rgba(96,165,250,0.75); }
    .g-card.cat-sicherheit::before{ background: rgba(248,113,113,0.75); }
    .g-card.cat-konzepte::before  { background: rgba(251,191,36,0.6); }

    /* ── Badges ── */
    .badge {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.58rem; letter-spacing: 0.06em; text-transform: uppercase;
      padding: 2px 7px; border-radius: 3px;
    }
    .badge-purple { background: rgba(167,139,250,0.1); color: rgba(167,139,250,0.85); border: 1px solid rgba(167,139,250,0.2); }
    .badge-blue   { background: rgba(96,165,250,0.1);  color: rgba(96,165,250,0.85);  border: 1px solid rgba(96,165,250,0.2); }
    .badge-red    { background: rgba(248,113,113,0.1); color: rgba(248,113,113,0.85); border: 1px solid rgba(248,113,113,0.2); }
    .badge-amber  { background: rgba(251,191,36,0.1);  color: rgba(251,191,36,0.85);  border: 1px solid rgba(251,191,36,0.2); }
    .badge-emerald{ background: rgba(52,211,153,0.1);  color: rgba(52,211,153,0.85);  border: 1px solid rgba(52,211,153,0.2); }
    .badge-indigo { background: rgba(129,140,248,0.1); color: rgba(129,140,248,0.85); border: 1px solid rgba(129,140,248,0.2); }

    /* ── Terminal window ── */
    .terminal { background: #050507; border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; overflow: hidden; }
    .t-bar { display: flex; align-items: center; gap: 6px; padding: 9px 14px; background: #0c0c0f; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .t-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .t-filename { font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; color: rgba(255,255,255,0.22); margin-left: auto; }
    .t-body { padding: 1.1rem 1.25rem; font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; line-height: 1.8; overflow-x: auto; color: #c0c0c0; }
    .t-body::-webkit-scrollbar { height: 3px; }
    .t-body::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 2px; }

    /* ── Filter pills ── */
    .f-pill {
      font-family: 'JetBrains Mono', monospace; font-size: 0.62rem;
      letter-spacing: 0.04em; padding: 4px 11px; border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.08); color: rgba(255,255,255,0.35);
      background: transparent; cursor: pointer; transition: all 150ms;
    }
    .f-pill:hover { border-color: rgba(255,255,255,0.16); color: rgba(255,255,255,0.65); }
    .f-pill.active { background: rgba(245,158,11,0.1); border-color: rgba(245,158,11,0.3); color: #f59e0b; }

    /* ── Nav chapter items ── */
    .nav-ch { display: flex; align-items: center; gap: 8px; padding: 5px 10px; border-radius: 6px; text-decoration: none; transition: background 150ms; }
    .nav-ch:hover { background: rgba(255,255,255,0.04); }
    .nav-ch.is-active { background: rgba(245,158,11,0.07); }
    .nav-ch .nav-num { font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; color: rgba(245,158,11,0.45); min-width: 18px; }
    .nav-ch .nav-lbl { font-size: 0.78rem; font-weight: 500; color: rgba(255,255,255,0.35); transition: color 150ms; }
    .nav-ch.is-active .nav-lbl { color: #f59e0b; }

    /* ── Search input ── */
    .g-search {
      width: 100%; background: #0d0d10; border: 1px solid rgba(255,255,255,0.08);
      border-radius: 8px; color: #e5e5e5;
      font-family: 'DM Sans', sans-serif; font-size: 0.875rem;
      padding: 9px 14px 9px 38px; outline: none;
      transition: border-color 200ms, box-shadow 200ms;
    }
    .g-search:focus { border-color: rgba(245,158,11,0.4); box-shadow: 0 0 0 3px rgba(245,158,11,0.08); }
    .g-search::placeholder { color: rgba(255,255,255,0.18); }

    /* ── Copy button ── */
    .copy-btn {
      font-family: 'JetBrains Mono', monospace; font-size: 0.58rem;
      letter-spacing: 0.05em; padding: 3px 8px; border-radius: 4px;
      border: 1px solid rgba(255,255,255,0.09); background: rgba(255,255,255,0.03);
      color: rgba(255,255,255,0.28); cursor: pointer; transition: all 150ms; white-space: nowrap;
    }
    .copy-btn:hover { border-color: rgba(255,255,255,0.18); color: rgba(255,255,255,0.65); }

    /* ── Inline code ── */
    .ic { font-family: 'JetBrains Mono', monospace; font-size: 0.78em; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.09); border-radius: 4px; padding: 1px 6px; color: #d4d4d4; }

    /* ── Step number circle ── */
    .step-n {
      width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Syne', sans-serif; font-size: 0.72rem; font-weight: 700;
      border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.4);
    }

    /* ── Scroll-reveal ── */
    .reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.55s ease, transform 0.55s ease; }
    .reveal.visible { opacity: 1; transform: none; }
    .reveal-d1 { transition-delay: 0.08s; }
    .reveal-d2 { transition-delay: 0.16s; }
    .reveal-d3 { transition-delay: 0.24s; }

    /* ── Type tiles ── */
    .type-tile {
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 10px;
      padding: 1rem;
      background: #0d0d10;
      transition: border-color 200ms;
    }
    .type-tile:hover { border-color: rgba(255,255,255,0.14); }

    /* ── Section divider ── */
    .s-divider { border: none; border-top: 1px solid rgba(255,255,255,0.05); margin: 0; }

    /* ── Dot grid hero bg ── */
    .dot-grid {
      background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px);
      background-size: 28px 28px;
    }
  </style>

  <main class="an-page">

    <!-- ═══════════════════════════════════════════ HERO -->
    <section class="relative overflow-hidden dot-grid border-b" style="border-color: rgba(255,255,255,0.05); min-height: 380px; display:flex; align-items:center;">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 60% at 50% 100%, rgba(245,158,11,0.05) 0%, transparent 70%);"></div>
      <div class="absolute bottom-0 left-0 right-0 h-40" style="background: linear-gradient(to top, #09090c, transparent);"></div>

      <div class="relative max-w-5xl mx-auto px-6 py-20 w-full">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full mb-8" style="background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.18);">
          <span style="width:5px;height:5px;border-radius:50%;background:#f59e0b;display:inline-block;"></span>
          <span class="f-mono" style="font-size:0.6rem;color:#f59e0b;letter-spacing:0.1em;text-transform:uppercase;">Einsteiger-Guide · Kein Vorwissen nötig</span>
        </div>

        <h1 class="f-syne mb-5" style="font-size:clamp(2.4rem,6vw,4.2rem);font-weight:800;line-height:1.06;letter-spacing:-0.03em;color:#efefef;">
          KI verstehen.<br>
          <span style="color:rgba(239,239,239,0.28);">Wirklich verstehen.</span>
        </h1>

        <p style="font-size:1rem;color:#5a5a5a;max-width:440px;line-height:1.75;font-weight:300;">
          Begriffe, Skills, APIs und Konfiguration — direkt erklärt, ohne Umwege.
        </p>

        <div class="flex flex-wrap gap-2 mt-8">
          {[
            { href:'#glossar', n:'01', label:'Begriffe' },
            { href:'#skills',  n:'02', label:'Skills' },
            { href:'#api',     n:'03', label:'API' },
            { href:'#env',     n:'04', label:'.env' },
          ].map(item => (
            <a href={item.href} class="flex items-center gap-2 px-4 py-2 rounded-lg transition-all" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);" onmouseover="this.style.borderColor='rgba(255,255,255,0.14)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.07)'">
              <span class="f-mono" style="font-size:0.58rem;color:#f59e0b;">{item.n}</span>
              <span style="font-size:0.82rem;color:#7a7a7a;">{item.label}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ STICKY NAV -->
    <div class="sticky top-0 z-40" style="background:rgba(9,9,12,0.92);backdrop-filter:blur(16px);border-bottom:1px solid rgba(255,255,255,0.05);">
      <div class="max-w-5xl mx-auto px-6">
        <nav class="flex items-center gap-1 py-2 overflow-x-auto" style="scrollbar-width:none;">
          {[
            { href:'#glossar', n:'01', label:'Begriffe' },
            { href:'#skills',  n:'02', label:'Skills einbinden' },
            { href:'#api',     n:'03', label:'API verbinden' },
            { href:'#env',     n:'04', label:'.env Dateien' },
          ].map(item => (
            <a href={item.href} class="nav-ch" data-target={item.href.slice(1)}>
              <span class="nav-num">{item.n}</span>
              <span class="nav-lbl whitespace-nowrap">{item.label}</span>
            </a>
          ))}
        </nav>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-6">

      <!-- ════════════════════════════════ §01 GLOSSAR -->
      <section id="glossar" class="py-20 scroll-mt-14">
        <div class="relative mb-10">
          <div class="s-watermark">01</div>
          <div class="flex items-center gap-3 mb-1">
            <span class="f-mono" style="font-size:0.62rem;color:#f59e0b;letter-spacing:0.1em;">§ 01</span>
          </div>
          <h2 class="f-syne" style="font-size:1.9rem;font-weight:800;color:#efefef;letter-spacing:-0.02em;">KI-Begriffe erklärt</h2>
          <p style="color:#4a4a4a;font-size:0.88rem;margin-top:6px;font-weight:300;">22 Fachbegriffe — einfach, ehrlich, mit Beispielen.</p>
        </div>

        <!-- Search + Filter -->
        <div class="flex flex-col sm:flex-row gap-3 mb-5 reveal">
          <div class="relative flex-1">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <input id="g-search" type="text" placeholder="Begriff suchen…" class="g-search" />
          </div>
          <div class="flex gap-1.5 flex-wrap" id="cat-filter">
            {cats.map(c => (
              <button data-cat={c} class={`f-pill ${c === 'Alle' ? 'active' : ''}`}>{c}</button>
            ))}
          </div>
        </div>

        <p class="f-mono mb-5" id="g-count" style="font-size:0.62rem;color:#333;letter-spacing:0.06em;">{glossary.length} BEGRIFFE</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2.5" id="g-grid">
          {glossary.map((g, i) => (
            <div
              class={`an-card g-card ${catClass[g.cat]} reveal ${i % 2 === 1 ? 'reveal-d1' : ''}`}
              data-cat={g.cat}
              data-term={g.term.toLowerCase()}
              data-def={g.def.toLowerCase()}
              style="padding-top:1rem;padding-bottom:1rem;padding-right:1rem;"
            >
