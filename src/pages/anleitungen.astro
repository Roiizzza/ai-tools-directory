<script>
  // ── Copy buttons ──
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = btn.dataset.copy ?? '';
      navigator.clipboard.writeText(text).then(() => {
        const orig = btn.textContent;
        btn.textContent = 'OK ✓';
        btn.style.color = 'rgba(52,211,153,0.8)';
        btn.style.borderColor = 'rgba(52,211,153,0.3)';
        setTimeout(() => {
          btn.textContent = orig;
          btn.style.color = '';
          btn.style.borderColor = '';
        }, 1500);
      });
    });
  });

  // ── Glossary search + filter ──
  const searchEl = document.getElementById('g-search') as HTMLInputElement;
  const filterBtns = document.querySelectorAll<HTMLElement>('#cat-filter button');
  const cards = document.querySelectorAll<HTMLElement>('#g-grid > div');
  const countEl = document.getElementById('g-count')!;
  const emptyEl = document.getElementById('g-empty')!;
  const gridEl = document.getElementById('g-grid')!;
  let activeCat = 'Alle';

  function applyFilter() {
    const q = searchEl.value.toLowerCase().trim();
    let n = 0;
    cards.forEach(card => {
      const matchCat = activeCat === 'Alle' || card.dataset.cat === activeCat;
      const matchQ = !q || (card.dataset.term ?? '').includes(q) || (card.dataset.def ?? '').includes(q);
      const show = matchCat && matchQ;
      card.classList.toggle('hidden', !show);
      if (show) n++;
    });
    countEl.textContent = `${n} BEGRIFFE`;
    emptyEl.classList.toggle('hidden', n > 0);
    gridEl.classList.toggle('hidden', n === 0);
  }

  searchEl.addEventListener('input', applyFilter);
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeCat = btn.dataset.cat ?? 'Alle';
      filterBtns.forEach(b => b.classList.toggle('active', b.dataset.cat === activeCat));
      applyFilter();
    });
  });

  // ── Nav active state ──
  const sections = document.querySelectorAll<HTMLElement>('section[id]');
  const navLinks = document.querySelectorAll<HTMLElement>('.nav-ch');
  const io = new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting)
        navLinks.forEach(l => l.classList.toggle('is-active', l.dataset.target === e.target.id));
    }),
    { rootMargin: '-20% 0px -65% 0px' }
  );
  sections.forEach(s => io.observe(s));

  // ── Scroll reveal ──
  const reveals = document.querySelectorAll<HTMLElement>('.reveal');
  const revealObs = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.08 }
  );
  reveals.forEach(el => revealObs.observe(el));
</script>
