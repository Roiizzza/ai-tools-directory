<script>
  // Copy buttons
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = btn.dataset.copy ?? '';
      navigator.clipboard.writeText(text).then(() => {
        const orig = btn.textContent;
        btn.textContent = '✓ Kopiert';
        setTimeout(() => { btn.textContent = orig; }, 1500);
      });
    });
  });

  // Glossary search + category filter
  const searchInput = document.getElementById('glossar-search') as HTMLInputElement;
  const catBtns = document.querySelectorAll<HTMLElement>('#cat-filter button');
  const cards = document.querySelectorAll<HTMLElement>('.glossar-card');
  const countEl = document.getElementById('glossar-count')!;
  const emptyEl = document.getElementById('glossar-empty')!;
  const gridEl = document.getElementById('glossar-grid')!;

  let activeCat = 'Alle';

  function filterGlossar() {
    const q = searchInput.value.toLowerCase().trim();
    let visible = 0;
    cards.forEach(card => {
      const matchCat = activeCat === 'Alle' || card.dataset.cat === activeCat;
      const matchQ = !q || (card.dataset.term ?? '').includes(q) || (card.dataset.def ?? '').includes(q);
      if (matchCat && matchQ) { card.classList.remove('hidden'); visible++; }
      else card.classList.add('hidden');
    });
    countEl.textContent = `${visible} Begriff${visible !== 1 ? 'e' : ''}`;
    emptyEl.classList.toggle('hidden', visible > 0);
    gridEl.classList.toggle('hidden', visible === 0);
  }

  searchInput.addEventListener('input', filterGlossar);

  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeCat = btn.dataset.cat ?? 'Alle';
      catBtns.forEach(b => {
        const isActive = b.dataset.cat === activeCat;
        b.className = `text-xs px-3 py-1.5 rounded-full border transition-colors ${isActive
          ? 'bg-cyan-900/60 border-cyan-700 text-cyan-300'
          : 'bg-zinc-900 border-zinc-700 text-zinc-400 hover:border-cyan-700 hover:text-white'}`;
      });
      filterGlossar();
    });
  });

  // Nav scroll highlight
  const sections = document.querySelectorAll<HTMLElement>('section[id]');
  const navLinks = document.querySelectorAll<HTMLElement>('.nav-anchor');

  const observer = new IntersectionObserver(
    entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          navLinks.forEach(link => {
            const active = link.getAttribute('href') === '#' + entry.target.id;
            link.classList.toggle('bg-zinc-800', active);
            link.classList.toggle('text-white', active);
            link.classList.toggle('text-zinc-400', !active);
          });
        }
      });
    },
    { rootMargin: '-20% 0px -70% 0px' }
  );

  sections.forEach(s => observer.observe(s));
</script>
