---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const glossary = [
  { term: 'LLM', full: 'Large Language Model', cat: 'Modelle', def: 'Ein KI-Modell, das auf riesigen Textmengen trainiert wurde und menschliche Sprache verstehen und erzeugen kann.', ex: 'GPT-4, Claude, Gemini, Llama sind bekannte LLMs.' },
  { term: 'Token', full: 'Textbaustein', cat: 'Konzepte', def: 'Kleinste Einheit, die ein LLM verarbeitet — ca. ¾ eines Wortes oder 4 Zeichen. Kosten und Limits werden in Tokens gemessen.', ex: '"Hallo Welt" ≈ 3 Tokens. 1.000 Tokens ≈ 750 Wörter.' },
  { term: 'Prompt', full: 'Eingabeaufforderung', cat: 'Konzepte', def: 'Der Text, den du an ein KI-Modell sendest. Die Qualität des Prompts bestimmt maßgeblich die Qualität der Antwort.', ex: '"Erkläre mir Python, als wäre ich 10 Jahre alt."' },
  { term: 'Context Window', full: 'Kontextfenster', cat: 'Konzepte', def: 'Die max. Anzahl Tokens, die ein Modell in einem Gespräch gleichzeitig "sehen" kann. Alles außerhalb wird vergessen.', ex: 'Claude: 200.000 Tokens ≈ 150.000 Wörter — ein ganzes Buch.' },
  { term: 'API', full: 'Application Programming Interface', cat: 'Werkzeuge', def: 'Schnittstelle zwischen Programmen. KI-APIs erlauben es, KI-Funktionen in eigene Apps einzubauen, ohne eigene Modelle zu betreiben.', ex: 'Du rufst die Anthropic API auf → Claude antwortet in deiner App.' },
  { term: 'API Key', full: 'API-Schlüssel', cat: 'Sicherheit', def: 'Ein einzigartiger Code, der dich als berechtigten API-Nutzer identifiziert. Wie ein Passwort — niemals teilen oder in Git committen!', ex: 'sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx' },
  { term: 'Halluzination', full: 'KI-Halluzination', cat: 'Konzepte', def: 'Wenn ein KI-Modell selbstbewusst falsche oder frei erfundene Informationen präsentiert. Das Modell "weiß" nicht, dass es falsch liegt.', ex: 'KI nennt eine nicht-existierende Studie mit korrektem Autor und Jahreszahl.' },
  { term: 'Temperature', full: 'Kreativitäts-Parameter', cat: 'Modelle', def: 'Steuert Kreativität und Zufälligkeit der Antworten. 0 = deterministisch und präzise. 1 = kreativ und variabel.', ex: 'Für Code: 0.2 empfohlen | Für Kreativtexte: 0.8–1.0' },
  { term: 'System Prompt', full: 'Systemanweisung', cat: 'Konzepte', def: 'Unsichtbare Vorabanweisung, die Modell-Verhalten, Persona und Regeln festlegt. Wird vor dem eigentlichen Chat gesetzt.', ex: '"Du bist ein präziser Assistent. Antworte immer auf Deutsch."' },
  { term: 'RAG', full: 'Retrieval Augmented Generation', cat: 'Konzepte', def: 'Technik: Erst relevante Dokumente aus einer Datenbank laden, dann dem Modell als Kontext geben. Reduziert Halluzinationen.', ex: 'Eigene PDFs durchsuchen lassen — ohne teures Fine-Tuning.' },
  { term: 'Fine-Tuning', full: 'Feinabstimmung', cat: 'Modelle', def: 'Ein vortrainiertes Modell mit eigenen Daten weitertrainieren, damit es für spezifische Aufgaben besser funktioniert.', ex: 'Modell auf Kundensupport-Dialoge trainieren → präzisere Antworten.' },
  { term: 'Embedding', full: 'Vektordarstellung', cat: 'Konzepte', def: 'Text wird in Zahlen-Vektoren umgewandelt, die semantische Ähnlichkeit abbilden. Basis für Suche, Empfehlungen und RAG.', ex: '"König" − "Mann" + "Frau" ≈ "Königin" — als Vektoren berechnet.' },
  { term: 'Agent', full: 'KI-Agent', cat: 'Werkzeuge', def: 'KI, die nicht nur antwortet, sondern selbstständig Aufgaben ausführt: Tools nutzen, Code ausführen, Browser steuern.', ex: 'Claude Code ist ein Agent — er liest, schreibt und verändert Dateien.' },
  { term: 'Open Source', full: 'Offener Quellcode', cat: 'Modelle', def: 'Modelle, deren Gewichte und Code öffentlich sind. Können lokal betrieben werden — keine API-Kosten, volle Kontrolle.', ex: 'Llama 3.1, Mistral, Qwen 2.5, Phi-4 sind Open-Source-Modelle.' },
  { term: 'Multimodal', full: 'Mehrmodale KI', cat: 'Modelle', def: 'KI-Modelle, die verschiedene Datentypen verarbeiten: Text, Bilder, Audio, Video — nicht nur Text.', ex: 'GPT-4o, Gemini 1.5 Pro, Claude 3 Opus sind multimodal.' },
  { term: 'Parameter', full: 'Modell-Parameter', cat: 'Modelle', def: 'Die "Gewichte" eines Modells — gelernte Verbindungen aus dem Training. Mehr Parameter = größere Kapazität.', ex: 'Llama 3.1: 405 Mrd. Parameter. GPT-4: ~1,7 Bio. (geschätzt).' },
  { term: 'Inference', full: 'Modell-Inferenz', cat: 'Modelle', def: 'Der Vorgang, wenn ein Modell eine Anfrage verarbeitet und antwortet. Jeder API-Call = eine Inference.', ex: 'Jede Antwort von Claude = ein Inference-Durchlauf auf Anthropic-Servern.' },
  { term: 'Prompt Engineering', full: 'Prompt-Gestaltung', cat: 'Konzepte', def: 'Die Kunst, Prompts so zu formulieren, dass KI-Modelle optimal antworten. Eigene Disziplin mit messbaren Qualitätsunterschieden.', ex: 'Chain-of-Thought: "Denke Schritt für Schritt..." verbessert Logik um ~30%.' },
  { term: 'MCP', full: 'Model Context Protocol', cat: 'Werkzeuge', def: 'Anthropic-Standard, um Claude mit externen Tools und Datenquellen zu verbinden. Wie eine universelle Steckdose für KI-Integrationen.', ex: 'MCP-Server für GitHub, Datenbanken, Browser-Steuerung, Dateisystem.' },
  { term: 'Benchmark', full: 'Leistungsvergleichstest', cat: 'Modelle', def: 'Standardisierte Tests zum Vergleich von KI-Modellen. Benchmark-Werte spiegeln nicht immer echte Alltagsqualität wider.', ex: 'MMLU (Wissen), HumanEval (Code), GPQA (Wissenschaft), LMSYS Arena.' },
  { term: 'Latenz', full: 'Antwortzeit', cat: 'Werkzeuge', def: 'Zeit zwischen Anfrage und erster Antwort. Kritisch für interaktive Apps. Gemessen als "Time to First Token" (TTFT).', ex: 'Schnelle Modelle: <500ms TTFT. Reasoning-Modelle: 10–60s.' },
  { term: 'CLAUDE.md', full: 'Konfigurations-Datei', cat: 'Werkzeuge', def: 'Spezielle Markdown-Datei, die Claude Code Projekt-Kontext gibt: Regeln, Codebase-Infos, Präferenzen. Wird automatisch geladen.', ex: 'CLAUDE.md im Projekt-Root ablegen → Claude kennt deine Regeln.' },
];

const cats = ['Alle', ...Array.from(new Set(glossary.map(g => g.cat))).sort()];

const builtinSkills = [
  { cmd: '/help',    desc: 'Alle verfügbaren Befehle anzeigen' },
  { cmd: '/clear',   desc: 'Kontext leeren — frische Unterhaltung starten' },
  { cmd: '/review',  desc: 'Code-Review für aktuelle Änderungen' },
  { cmd: '/init',    desc: 'CLAUDE.md Konfigurationsdatei erstellen' },
  { cmd: '/compact', desc: 'Kontext komprimieren (Platz sparen)' },
  { cmd: '/config',  desc: 'Claude Code Einstellungen öffnen' },
  { cmd: '/cost',    desc: 'API-Kosten der aktuellen Sitzung anzeigen' },
  { cmd: '/status',  desc: 'Git-Status und aktuelle Aufgaben anzeigen' },
];

const customSkillContent = `---
name: mein-skill
description: Analysiert Code und gibt Verbesserungsvorschläge
---

Analysiere den aktuellen Code und gib genau 3 konkrete,
priorisierte Verbesserungsvorschläge:

1. Sicherheit & Bugs — was könnte kaputt gehen?
2. Performance — wo ist es langsam oder ineffizient?
3. Lesbarkeit — was ist schwer zu verstehen?

Halte jeden Vorschlag unter 3 Sätzen. Sei direkt.`;

const envExampleRaw = `# KI-APIs
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
GOOGLE_AI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxx

# Datenbank
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# App-Konfiguration
APP_PORT=3000
NODE_ENV=development
DEBUG=false`;

const envExampleForCopy = envExampleRaw;
const gitignoreContent = `.env\n.env.local\n.env.*.local\n.env.production`;

const catColors: Record<string, string> = {
  Modelle: 'bg-purple-950/50 border-purple-800/50 text-purple-400',
  Werkzeuge: 'bg-indigo-950/50 border-indigo-800/50 text-indigo-400',
  Sicherheit: 'bg-red-950/50 border-red-800/50 text-red-400',
  Konzepte: 'bg-zinc-800 border-zinc-700 text-zinc-400',
};
---

<Layout
  title="Anleitungen für KI-Einsteiger — Skills, API, .env erklärt"
  description="KI-Glossar mit 22 Begriffen, Claude Skills einbinden, API Keys verbinden, .env Dateien richtig nutzen — alles für Einsteiger erklärt."
>
  <Header />

  <main class="max-w-5xl mx-auto px-4 py-10">

    <!-- Hero -->
    <section class="text-center mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cyan-950/60 border border-cyan-800/50 text-xs text-cyan-400 mb-5">
        <span class="text-base">📚</span>
        Für Einsteiger — kein Vorwissen nötig
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3 leading-tight">
        KI verstehen &amp; nutzen
      </h1>
      <p class="text-zinc-400 text-base max-w-xl mx-auto">
        Begriffe erklärt. Skills eingebunden. API verbunden. .env gemeistert.
      </p>
    </section>

    <!-- Sticky Nav -->
    <div class="sticky top-0 z-40 -mx-4 px-4 mb-12 backdrop-blur-md bg-zinc-950/90 border-b border-zinc-800/80 py-3">
      <nav class="flex gap-1 overflow-x-auto max-w-5xl mx-auto">
        {[
          { href: '#glossar', label: 'Begriffe',        icon: '📖' },
          { href: '#skills',  label: 'Skills einbinden', icon: '⚡' },
          { href: '#api',     label: 'API verbinden',    icon: '🔑' },
          { href: '#env',     label: '.env Dateien',     icon: '🔒' },
        ].map(n => (
          <a
            href={n.href}
            class="nav-anchor flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm text-zinc-400 hover:text-white hover:bg-zinc-800 transition-all whitespace-nowrap"
          >
            <span>{n.icon}</span>
            {n.label}
          </a>
        ))}
      </nav>
    </div>


    <!-- ══════════════════════════════════════════════════════ -->
    <!-- 1. GLOSSAR                                             -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section id="glossar" class="mb-24 scroll-mt-16">

      <div class="flex items-center gap-3 mb-1">
        <div class="w-8 h-8 rounded-lg bg-cyan-950/60 border border-cyan-800/50 flex items-center justify-center text-sm">📖</div>
        <h2 class="text-2xl font-bold text-white">KI-Begriffe erklärt</h2>
      </div>
      <p class="text-zinc-500 text-sm mb-6 ml-11">Die wichtigsten Fachbegriffe — einfach, ehrlich, mit Beispielen.</p>

      <!-- Search + Filter -->
      <div class="flex flex-col sm:flex-row gap-3 mb-5">
        <div class="relative flex-1">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500 text-sm pointer-events-none">🔍</span>
          <input
            id="glossar-search"
            type="text"
            placeholder="Begriff suchen..."
            class="w-full bg-zinc-900 border border-zinc-700 rounded-lg pl-9 pr-4 py-2 text-sm text-white placeholder-zinc-500 focus:outline-none focus:border-cyan-600 transition-colors"
          />
        </div>
        <div class="flex gap-2 flex-wrap" id="cat-filter">
          {cats.map(c => (
            <button
              data-cat={c}
              class={`text-xs px-3 py-1.5 rounded-full border transition-colors ${c === 'Alle' ? 'bg-cyan-900/60 border-cyan-700 text-cyan-300' : 'bg-zinc-900 border-zinc-700 text-zinc-400 hover:border-cyan-700 hover:text-white'}`}
            >
              {c}
            </button>
          ))}
        </div>
      </div>

      <p class="text-zinc-600 text-xs mb-4" id="glossar-count">{glossary.length} Begriffe</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" id="glossar-grid">
        {glossary.map(g => (
          <div
            class="glossar-card rounded-xl border border-zinc-800 bg-[#1a1a1a] p-4 hover:border-cyan-800/50 transition-all"
            data-cat={g.cat}
            data-term={g.term.toLowerCase()}
            data-def={g.def.toLowerCase()}
          >
            <div class="flex items-start justify-between gap-2 mb-2">
              <div class="min-w-0">
                <span class="text-sm font-bold text-white">{g.term}</span>
                <span class="text-xs text-zinc-500 ml-1.5 hidden sm:inline">— {g.full}</span>
              </div>
              <span class={`text-xs px-2 py-0.5 rounded-full border flex-none ${catColors[g.cat] ?? catColors.Konzepte}`}>{g.cat}</span>
            </div>
            <p class="text-xs text-zinc-400 leading-relaxed mb-2">{g.def}</p>
            <div class="flex items-start gap-1.5">
              <span class="text-xs text-zinc-600 flex-none mt-px">Bsp:</span>
              <code class="text-xs text-cyan-400/80 font-mono leading-relaxed break-all">{g.ex}</code>
            </div>
          </div>
        ))}
      </div>

      <p id="glossar-empty" class="hidden text-center text-zinc-600 py-8 text-sm">Kein Begriff gefunden.</p>

    </section>


    <!-- ══════════════════════════════════════════════════════ -->
    <!-- 2. SKILLS EINBINDEN                                    -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section id="skills" class="mb-24 scroll-mt-16">

      <div class="flex items-center gap-3 mb-1">
        <div class="w-8 h-8 rounded-lg bg-purple-950/60 border border-purple-800/50 flex items-center justify-center text-sm">⚡</div>
        <h2 class="text-2xl font-bold text-white">Skills einbinden</h2>
      </div>
      <p class="text-zinc-500 text-sm mb-8 ml-11">Claude Code Skills sind Slash-Commands — von eingebaut bis selbst erstellt.</p>

      <!-- Was sind Skills -->
      <div class="rounded-xl border border-zinc-800 bg-[#1a1a1a] p-5 mb-8">
        <h3 class="text-sm font-bold text-white mb-2">Was ist ein Skill?</h3>
        <p class="text-sm text-zinc-400 leading-relaxed mb-4">
          Skills sind Slash-Commands in Claude Code —
          <code class="bg-zinc-800 px-1.5 py-0.5 rounded text-purple-300 text-xs">/review</code>,
          <code class="bg-zinc-800 px-1.5 py-0.5 rounded text-purple-300 text-xs">/init</code> oder
          <code class="bg-zinc-800 px-1.5 py-0.5 rounded text-purple-300 text-xs">/mein-skill</code>.
          Du tippst den Befehl, Claude führt eine vorbereitete Aufgabe aus. Es gibt 4 Typen:
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
          {[
            { type: 'Built-in',    desc: 'Standard-Befehle von Anthropic. Immer verfügbar.',  color: 'emerald' },
            { type: 'Marketplace', desc: 'Von der Community erstellt. Einfach installierbar.', color: 'indigo'  },
            { type: 'Community',   desc: 'GitHub-Skills, direkt einbindbar.',                  color: 'amber'   },
            { type: 'Custom',      desc: 'Deine eigenen, selbst erstellten Skills.',            color: 'purple'  },
          ].map(t => (
            <div class={`rounded-lg border p-3 text-center ${
              t.color === 'emerald' ? 'border-emerald-800/50 bg-emerald-950/20' :
              t.color === 'indigo'  ? 'border-indigo-800/50 bg-indigo-950/20'  :
              t.color === 'amber'   ? 'border-amber-800/50 bg-amber-950/20'    :
                                      'border-purple-800/50 bg-purple-950/20'
            }`}>
              <div class={`text-sm font-bold mb-1 ${
                t.color === 'emerald' ? 'text-emerald-400' :
                t.color === 'indigo'  ? 'text-indigo-400'  :
                t.color === 'amber'   ? 'text-amber-400'   :
                                        'text-purple-400'
              }`}>{t.type}</div>
              <div class="text-xs text-zinc-500 leading-snug">{t.desc}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Built-in Skills -->
      <div class="mb-8">
        <h3 class="text-base font-bold text-white mb-1 flex items-center gap-2">
          <span class="w-5 h-5 rounded bg-emerald-900/60 border border-emerald-700/50 flex items-center justify-center text-xs text-emerald-400 flex-none">1</span>
          Built-in Skills — kein Setup nötig
        </h3>
        <p class="text-sm text-zinc-500 mb-3 ml-7">Einfach in Claude Code eintippen:</p>
        <div class="rounded-xl border border-zinc-800 bg-[#1a1a1a] overflow-hidden ml-7">
          {builtinSkills.map((s, i) => (
            <div class={`flex items-center gap-4 px-4 py-3 ${i < builtinSkills.length - 1 ? 'border-b border-zinc-800/60' : ''}`}>
              <code class="text-sm font-mono text-emerald-300 w-24 flex-none">{s.cmd}</code>
              <span class="text-sm text-zinc-400">{s.desc}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Marketplace Skills -->
      <div class="mb-8">
        <h3 class="text-base font-bold text-white mb-1 flex items-center gap-2">
          <span class="w-5 h-5 rounded bg-indigo-900/60 border border-indigo-700/50 flex items-center justify-center text-xs text-indigo-400 flex-none">2</span>
          Marketplace Skills installieren
        </h3>
        <p class="text-sm text-zinc-500 mb-4 ml-7">Skills aus dem offiziellen Marketplace hinzufügen:</p>
        <div class="space-y-3 ml-7">

          <div class="rounded-xl border border-zinc-800 bg-[#1a1a1a] p-4">
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-indigo-900/60 border border-indigo-700/50 flex items-center justify-center text-xs text-indigo-400 flex-none">1</span>
              <div>
                <div class="text-sm font-bold text-white mb-1">Marketplace öffnen</div>
                <p class="text-xs text-zinc-400">Gehe zu <code class="bg-zinc-800 px-1 rounded">claude.ai/marketplace</code> oder direkt in Claude Code mit:</p>
                <div class="flex items-center gap-2 bg-zinc-900 rounded-lg px-3 py-2 border border-zinc-700 mt-2">
                  <code class="text-xs font-mono text-indigo-300 flex-1">/marketplace</code>
                  <button class="copy-btn text-xs text-zinc-500 hover:text-white px-2 py-1 bg-zinc-800 rounded border border-zinc-700" data-copy="/marketplace">Kopieren</button>
                </div>
              </div>
            </div>
          </div>

          <div class="rounded-xl border border-zinc-800 bg-[#1a1a1a] p-4">
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-indigo-900/60 border border-indigo-700/50 flex items-center justify-center text-xs text-indigo-400 flex-none">2</span>
              <div>
                <div class="text-sm font-bold text-white mb-1">Skill direkt installieren</div>
                <p class="text-xs text-zinc-400 mb-2">Den Skill-Namen kennst du? Installiere ihn mit einem Befehl:</p>
                <div class="flex items-center gap-2 bg-zinc-900 rounded-lg px-3 py-2 border border-zinc-700">
                  <code class="text-xs font-mono text-indigo-300 flex-1">/marketplace install &lt;skill-name&gt;</code>
                  <button class="copy-btn text-xs text-zinc-500 hover:text-white px-2 py-1 bg-zinc-800 rounded border border-zinc-700" data-copy="/marketplace install skill-name">Kopieren</button>
                </div>
              </div>
            </div>
          </div>

          <div class="rounded-xl border border-zinc-800 bg-[#1a1a1a] p-4">
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-indigo-900/60 border border-indigo-700/50 flex items-center justify-center text-xs text-indigo-400 flex-none">3</span>
              <div>
                <div class="text-sm font-bold text-white mb-1">Nutzen</div>
                <p class="text-xs text-zinc-400 mb-2">Sofort verfügbar — tippe in Claude Code:</p>
                <div class="flex items-center gap-2 bg-zinc-900 rounded-lg px-3 py-2 border border-zinc-700">
                  <code class="text-xs font-mono text-indigo-300 flex-1">/&lt;skill-name&gt;</code>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- Custom Skills -->
      <div>
        <h3 class="text-base font-bold text-white mb-1 flex items-center gap-2">
          <span class="w-5 h-5 rounded bg-purple-900/60 border border-purple-700/50 flex items-center justify-center text-xs text-purple-400 flex-none">3</span>
          Eigene Custom Skills erstellen
        </h3>
        <p class="text-sm text-zinc-500 mb-4 ml-7">Eine einfache .md Datei anlegen — das ist alles.</p>

        <div class="ml-7 space-y-4">
          <!-- Pfad global -->
          <div class="rounded-xl border border-zinc-800 bg-[#1a1a1a] p-4">
            <p class="text-xs text-zinc-500 mb-2 font-medium uppercase tracking-wide">Speicherort — global (alle Projekte)</p>
            <div class="flex items-center gap-2 bg-zinc-900 rounded-lg px-3 py-2.5 border border-zinc-700">
              <code class="text-sm font-mono text-purple-300 flex-1">~/.claude/commands/mein-skill.md</code>
              <button class="copy-btn text-xs text-zinc-500 hover:text-white px-2 py-1 bg-zinc-800 rounded border border-zinc-700" data-copy="~/.claude/commands/mein-skill.md">Kopieren</button>
            </div>
            <p class="text-xs text-zinc-600 mt-2">Alternativ nur für dieses Projekt: <code class="bg-zinc-800 px-1 rounded">.claude/commands/mein-skill.md</code></p>
          </div>

          <!-- Datei-Inhalt -->
          <div class="rounded-xl border border-zinc-800 bg-[#1a1a1a] overflow-hidden">
            <div class="flex items-center justify-between px-4 py-2.5 border-b border-zinc-800 bg-zinc-900/60">
              <span class="text-xs text-zinc-500 font-mono">mein-skill.md</span>
              <button class="copy-btn text-xs text-zinc-500 hover:text-white px-2 py-1 bg-zinc-800 rounded border border-zinc-700" data-copy={customSkillContent}>Kopieren</button>
            </div>
            <pre class="text-xs font-mono text-zinc-300 p-4 leading-relaxed overflow-x-auto">{customSkillContent}</pre>
          </div>

          <!-- Erklärung -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-xs">
            <div class="rounded-lg border border-zinc-800 bg-zinc-900/30 p-3">
              <div class="font-bold text-zinc-300 mb-1">--- Frontmatter ---</div>
              <div class="text-zinc-500 leading-relaxed"><code class="text-purple-300">name</code>: wird zum Befehlsnamen<br/><code class="text-purple-300">description</code>: erscheint in /help</div>
            </div>
            <div class="rounded-lg border border-zinc-800 bg-zinc-900/30 p-3">
              <div class="font-bold text-zinc-300 mb-1">Inhalt = Aufgabe</div>
              <div class="text-zinc-500 leading-relaxed">Alles nach dem --- ist der Prompt, den Claude beim Aufruf ausführt. Sei präzise.</div>
            </div>
            <div class="rounded-lg border border-zinc-800 bg-zinc-900/30 p-3">
