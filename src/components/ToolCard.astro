---
import PriceBadge from './PriceBadge.astro';

interface Tool {
  id: string;
  name: string;
  tagline: string;
  description: string;
  logo_url?: string;
  website: string;
  strengths: string[];
  weaknesses: string[];
  pricing: { model: string; free_tier?: boolean; starting_price?: number; currency?: string; price_note?: string };
  tags: string[];
  is_open_source?: boolean;
  editor_pick?: boolean;
  last_updated?: string;
}

interface Props {
  tool: Tool;
  categorySlug?: string;
}

const { tool, categorySlug } = Astro.props;
const initials = tool.name.slice(0, 2).toUpperCase();
const strengths = tool.strengths.slice(0, 3);
const weaknesses = tool.weaknesses.slice(0, 2);
---

<div
  class="relative flex flex-col rounded-xl border border-zinc-800 bg-[#1a1a1a] p-5 hover:border-indigo-500/50 hover:shadow-[0_0_20px_rgba(99,102,241,0.15)] transition-all duration-200"
  data-name={tool.name.toLowerCase()}
  data-tagline={tool.tagline.toLowerCase()}
  data-tags={tool.tags.join(' ').toLowerCase()}
  data-category={categorySlug ?? ''}
>
  {tool.editor_pick && (
    <span class="absolute top-3 right-3 text-xs font-semibold px-2 py-0.5 rounded-full bg-indigo-900/60 border border-indigo-700 text-indigo-300">
      ★ Editor's Pick
    </span>
  )}

  <!-- Header -->
  <div class="flex items-start gap-3 mb-3">
    <div class="flex-none w-10 h-10 rounded-lg overflow-hidden bg-zinc-800 flex items-center justify-center text-sm font-bold text-zinc-400">
      {tool.logo_url ? (
        <img
          src={tool.logo_url}
          alt={tool.name}
          width="40"
          height="40"
          class="w-full h-full object-contain"
          onerror="this.style.display='none';this.nextSibling.style.display='flex'"
        />
      ) : null}
      <span class={tool.logo_url ? 'hidden' : ''}>{initials}</span>
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <h3 class="font-bold text-white text-base leading-tight">{tool.name}</h3>
        {tool.is_open_source && (
          <span class="text-xs px-1.5 py-0.5 rounded bg-zinc-700 text-zinc-400">OSS</span>
        )}
      </div>
      <p class="text-xs text-zinc-400 mt-0.5 leading-snug">{tool.tagline}</p>
    </div>
  </div>

  <!-- Description -->
  <p class="text-sm text-zinc-300 leading-relaxed mb-3 line-clamp-2">{tool.description}</p>

  <!-- Strengths -->
  <ul class="space-y-1 mb-3">
    {strengths.map(s => (
      <li class="flex items-start gap-1.5 text-xs text-emerald-400">
        <span class="mt-0.5 flex-none">✓</span>
        <span>{s}</span>
      </li>
    ))}
  </ul>

  <!-- Weaknesses -->
  <ul class="space-y-1 mb-4">
    {weaknesses.map(w => (
      <li class="flex items-start gap-1.5 text-xs text-red-400">
        <span class="mt-0.5 flex-none">✗</span>
        <span>{w}</span>
      </li>
    ))}
  </ul>

  <!-- Tags -->
  <div class="flex flex-wrap gap-1.5 mb-4">
    {tool.tags.slice(0, 5).map(tag => (
      <span class="text-xs px-2 py-0.5 rounded-full bg-zinc-800 text-zinc-400 border border-zinc-700">{tag}</span>
    ))}
  </div>

  <!-- Footer -->
  <div class="mt-auto flex items-center justify-between pt-3 border-t border-zinc-800">
    <PriceBadge pricing={tool.pricing} />
    <div class="flex items-center gap-3">
      {categorySlug && (
        <a
          href={`/tool/${categorySlug}/${tool.id}`}
          class="text-xs font-medium text-zinc-400 hover:text-white transition-colors"
        >
          Details
        </a>
      )}
      <a
        href={tool.website}
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs font-medium text-indigo-400 hover:text-indigo-300 transition-colors"
      >
        Website →
      </a>
    </div>
  </div>
  {tool.last_updated && (
    <p class="text-[10px] text-zinc-600 mt-2">Aktualisiert: {tool.last_updated}</p>
  )}
</div>
